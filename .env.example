# SloppyRoad — Environment Variables
# Copy to .env and fill in required values.
# All variables use the AIWN_ prefix.

# ── Required ──────────────────────────────────────────────────────────
AIWN_JWT_SECRET_KEY=change-me-to-a-random-64-char-string

# ── Database (production uses PostgreSQL) ─────────────────────────────
# AIWN_DATABASE_URL=postgresql+asyncpg://aiwn:password@db:5432/aiwn
# AIWN_DB_PASSWORD=aiwn_dev

# ── Redis ──────────────────────────────────────────────────────────────
# AIWN_REDIS_URL=redis://localhost:6379
# AIWN_REDIS_PASSWORD=

# ── LLM Provider ─────────────────────────────────────────────────────
# AIWN_LITELLM_API_KEY=sk-...

# ── Image Generation ─────────────────────────────────────────────────
# AIWN_REPLICATE_API_TOKEN=r8_...

# ── BYOK Encryption (Fernet key for storing author API keys) ─────────
# AIWN_ENCRYPTION_KEY=generate-with-python-cryptography-fernet

# ── Email (verification emails via Resend) ───────────────────────────
# AIWN_RESEND_API_KEY=re_...

# ── Stripe (optional) ────────────────────────────────────────────────
# AIWN_STRIPE_API_KEY=sk_test_...
# AIWN_STRIPE_WEBHOOK_SECRET=whsec_...

# ── Error Tracking (optional) ────────────────────────────────────────
# SENTRY_DSN=https://...@sentry.io/...

# ── Debug (set to true for development) ──────────────────────────────
# AIWN_DEBUG=false
# AIWN_LOG_LEVEL=INFO
